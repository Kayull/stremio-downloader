{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stremio Downloader",
  "version": "2.0.1",
  "identifier": "io.github.kayull.stremio-downloader",
  "build": {
    "frontendDist": "static"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": []
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "stremio-downloader"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "appimage",
      "deb",
      "nsis"
    ],
    "resources": [
      "../build/desktop-runtime",
      "../build/node-runtime"
    ],
    "externalBin": [
      "binaries/node-launcher"
    ],
    "icon": [
      "../packaging/icons/32x32.png",
      "../packaging/icons/128x128.png",
      "../packaging/icons/128x128@2x.png",
      "../packaging/icons/icon.png",
      "../packaging/icons/downloader.icns",
      "../packaging/icons/downloader.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
